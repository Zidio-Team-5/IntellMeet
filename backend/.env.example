# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated. Frontend dev server origin(s) and your deployed origin.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Public URL of the frontend — used to build shareable meeting links.
# In production set this to your Vercel URL, e.g. https://intellmeet.vercel.app
CLIENT_URL=http://localhost:3000

# Auth — set a strong secret in production (the server refuses to start in
# production without one).
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=7d

# Database — REQUIRED. A MongoDB connection string (Atlas or local). The server
# fails fast on startup if this is missing.
MONGO_URI=

# AI (optional) — without a key, AI endpoints return simulated output
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Email (optional but recommended) — Gmail SMTP via Nodemailer, free.
# Without these, OTP/notification emails are skipped (logged only), the app
# still works. See docs/NEW_FEATURES_SETUP.md for how to get a Gmail App
# Password (requires 2-Step Verification on that Google account).
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# One-time use only — with server/src/scripts/bootstrapAdmin.js
# (npm run bootstrap-admin). Not read by the running server.
DEMO_ADMIN_NAME=
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=

# Google Drive (optional) — required only for meeting recording uploads.
# Each user connects their OWN Drive from Settings; recordings for meetings
# they host upload there. Without these, everything else works normally —
# the Record button just returns "Drive isn't configured" if clicked.
# See docs/NEW_FEATURES_SETUP.md for the exact Google Cloud Console steps.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
