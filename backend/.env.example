# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated. Frontend dev server origin(s).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth — set a strong secret in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=7d

# Database — leave blank to run with the in-memory mock (dev only)
MONGO_URI=

# AI (optional) — without a key, AI endpoints return simulated output
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
