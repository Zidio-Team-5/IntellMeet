VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_APP_NAME=IntellMeet
VITE_APP_VERSION=2.0.0

# TURN server (optional) — a free public one (Open Relay Project) is used by
# default so audio/video/screen-share work across real networks out of the
# box. Override these once you have dedicated TURN credentials (recommended
# for production - the free one is rate-limited).
VITE_TURN_URL=
VITE_TURN_URL_TLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
